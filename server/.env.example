# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

# ── Database ───────────────────────────────────────────
# For local (non-docker) dev:  mongodb://127.0.0.1:27017/resumify
# Inside docker-compose the host is the service name `mongo`:
MONGO_URI=mongodb://mongo:27017/resumify

# ── Auth ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# ── Uploads ────────────────────────────────────────────
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE_MB=5

# ── AI (Google Gemini) ─────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
